{
  "name": "primeng-forms-utils",
  "version": "0.1.0",
  "description": "Angular utility library for dynamic forms built on top of PrimeNG.",
  "keywords": [
    "angular",
    "primeng",
    "forms",
    "dynamic-forms",
    "typescript"
  ],
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/fesm2022/primeng-forms-utils.mjs",
  "module": "./dist/fesm2022/primeng-forms-utils.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/fesm2022/primeng-forms-utils.mjs"
    }
  },
  "files": [
    "dist",
    "src",
    "demo"
  ],
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "build:demo": "ng build demo-showcase",
    "start:demo": "ng serve demo-showcase",
    "watch:demo": "ng build demo-showcase --watch"
  },
  "peerDependencies": {
    "@angular/common": "^18.0.0",
    "@angular/compiler": "^18.0.0",
    "@angular/core": "^18.0.0",
    "@angular/forms": "^18.0.0",
    "primeng": "^18.0.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.21",
    "@angular/animations": "^18.2.13",
    "@angular/cdk": "^18.2.14",
    "@angular/cli": "^18.2.21",
    "@angular/common": "^18.2.13",
    "@angular/compiler": "^18.2.13",
    "@angular/compiler-cli": "^18.0.0",
    "@angular/core": "^18.2.13",
    "@angular/forms": "^18.2.13",
    "@angular/platform-browser": "^18.2.13",
    "@angular/router": "^18.2.13",
    "@primeng/themes": "^18.0.2",
    "ng-packagr": "^18.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^18.0.0",
    "rxjs": "^7.8.1",
    "tslib": "^2.8.1",
    "typescript": "^5.5.4",
    "zone.js": "^0.14.10"
  }
}
